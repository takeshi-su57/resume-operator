# LLM Provider Configuration
LLM_PROVIDER=openai          # openai | anthropic | google | openrouter
LLM_MODEL=gpt-4o             # Model name (provider-specific)

# API Keys (set the one matching your LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Logging
LOG_LEVEL=INFO

# ATS Score Threshold — skip optimization when score is at or above this value
ATS_SKIP_THRESHOLD=0.9
